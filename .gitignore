# =============================================================================
# Portraits-AI: .gitignore
# =============================================================================
# IMPORTANT: This project treats IMAGES as DATA, not code. Images are regenerated
# from the scraping pipeline. We only track CODE and CONFIGURATION.
# =============================================================================

# =============================================================================
# DATASETS - Imágenes generadas por el pipeline (NO trackear)
# =============================================================================
Retratos/Siglo*/
Retratos/00_DESCARTADOS/
Retratos/01_RECORTE_FINAL/
01_RECORTE_FINAL/

# Optional: If you want to track haarcascade XML (needed by code as fallback):
 Retratos/haarcascade_frontalface_default.xml

# =============================================================================
# PYTHON - Entornos virtuales y cache
# =============================================================================
venv/
env/
.venv/
env/
*.py[cod]
$py.class
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/
.tox/

# =============================================================================
# THIRD-PARTY WHEELS - Instalar desde requirements.txt, no trackear
# =============================================================================
*.whl

# =============================================================================
# ENV Y SECRETS
# =============================================================================
.env
.env.local
*.pem

# =============================================================================
# OS - Archivos temporales del sistema
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.Trash/

# =============================================================================
# LOGS Y OUTPUTS GENERADOS
# =============================================================================
logs/
*.log
portraits_*.log

# =============================================================================
# IDEs Y EDITORES
# =============================================================================
.vscode/
.idea/
*.sublime-*

# =============================================================================
# CACHE DIRECTORIES
# =============================================================================
.ruff_cache/
.mypy_cache/